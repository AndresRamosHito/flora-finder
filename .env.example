# OrquIDea environment — copy to .env and fill with YOUR Supabase project's values
# (Supabase dashboard → Settings → API). The anon/publishable key is safe to expose.
# See supabase/SETUP.md for the full self-hosting guide.

VITE_SUPABASE_URL="https://<YOUR_PROJECT_REF>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<YOUR_ANON_PUBLISHABLE_KEY>"
VITE_SUPABASE_PROJECT_ID="<YOUR_PROJECT_REF>"

# Server-side (SSR) fallbacks — same values as above.
SUPABASE_URL="https://<YOUR_PROJECT_REF>.supabase.co"
SUPABASE_PUBLISHABLE_KEY="<YOUR_ANON_PUBLISHABLE_KEY>"
